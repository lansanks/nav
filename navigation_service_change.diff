+    def _resolve_sensor_slice(self, sensor_name: str, expected_dim: int = None, warn_on_missing: bool = True):
+        sensor_id = mujoco.mj_name2id(self.model, mujoco.mjtObj.mjOBJ_SENSOR, sensor_name)
+        if sensor_id < 0:
+            if warn_on_missing:
