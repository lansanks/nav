#!/usr/bin/env python3
"""Core-only launcher for the navigation ROS 2 launch file."""

from __future__ import annotations

import glob
import os
import re
import shlex
import signal
import subprocess
import threading
from datetime import datetime
from pathlib import Path
import tkinter as tk
from tkinter import messagebox, ttk


UNITREE_CYCLONEDDS_SETUP = Path.home() / "unitree_ros2" / "cyclonedds_ws" / "install" / "setup.bash"

LIDAR_WS = Path.home() / "lidar" / "radar" / "unilidar" / "unitree_lidar_ros2"
LIVOX_WS = Path.home() / "lidar" / "radar" / "livox" / "livox_ws"
FAST_LIO_WS = Path.home() / "lidar" / "lio" / "fast_lio_ws"
FAST_LIO_CONFIG_DIR = FAST_LIO_WS / "src" / "FAST_LIO_ROS2" / "config"
FAST_LIO_MAP_ROOT = Path.home() / "lidar" / "lio" / "maps"
FAST_LIO_DEFAULT_SAVE_DIR = FAST_LIO_MAP_ROOT / "map"
TEMP_CONFIG_DIR = Path("/tmp/navigation_core_launcher_fast_lio")
DEFAULT_CALIBRATION_FILE = "radar_points__to__cali505.yaml"
NO_CALIBRATION_LABEL = "无"
NO_CALIBRATION_PATH = Path("/tmp/navigation_core_launcher_no_calibration.yaml")

LIDAR_INIT_DELAY = 2
FAST_LIO_INIT_DELAY = 2
LIDAR_TOPIC_TIMEOUT = 10
FAST_LIO_TOPIC_TIMEOUT = 12
MAP_SAVE_TIMEOUT = 30
FAST_LIO_ODOM_TOPIC = "/Odometry"
SELF_CHECK_MARKER = "__NAVIGATION_CORE_SELF_CHECK__:"


def detect_workspace_setup() -> tuple[Path | None, Path]:
    script_path = Path(__file__).resolve()
    for parent in script_path.parents:
        setup_candidates = [
            parent / "install" / "setup.bash",
            parent / "install" / "local_setup.bash",
            parent / "setup.bash",
            parent / "local_setup.bash",
        ]
        for setup in setup_candidates:
            if setup.exists():
                workspace = setup.parent.parent if setup.parent.name == "install" else setup.parent
                return setup, workspace

    for prefix_text in os.environ.get("AMENT_PREFIX_PATH", "").split(os.pathsep):
        if not prefix_text:
            continue
        prefix = Path(prefix_text)
        for setup_name in ("setup.bash", "local_setup.bash"):
            setup = prefix / setup_name
            if setup.exists():
                return setup, prefix

    return None, script_path.parent


def detect_ros_setup() -> Path | None:
    distro = os.environ.get("ROS_DISTRO")
    candidates: list[Path] = []
    if distro:
        candidates.append(Path("/opt/ros") / distro / "setup.bash")
    candidates.extend(Path(path) for path in sorted(glob.glob("/opt/ros/*/setup.bash")))
    for candidate in candidates:
        if candidate.exists():
            return candidate
    return None


class NavigationCoreLauncher(tk.Tk):
    def __init__(self) -> None:
        super().__init__()
        self.title("Navigation Core Launcher")
        self.geometry("780x500")
        self.minsize(720, 460)

        self.process: subprocess.Popen[str] | None = None
        self.process_pgid: int | None = None
        self.reader_thread: threading.Thread | None = None
        self.self_check_failed = False
        self.close_after_stop = False
        self.running_mode: str | None = None
        self.mapping_output_path: Path | None = None

        self.config_var = tk.StringVar(value=self._default_config_file())
        self.pcd_var = tk.StringVar(value="")
        self.calibration_var = tk.StringVar(value=self._default_calibration_file())
        self.race_logic_var = tk.StringVar(value="mission")
        self.mission_resume_event_var = tk.StringVar(value="completed")
        self.mission_task_radius_var = tk.StringVar(value="0.40")
        self.mission_arm_retry_period_var = tk.StringVar(value="1.0")

        self._build_ui()
        self._refresh_pcd_files(select_first=True)
        self._refresh_calibration_files(select_default=True)
        self.protocol("WM_DELETE_WINDOW", self._on_close)

    def _build_ui(self) -> None:
        root = ttk.Frame(self, padding=6)
        root.grid(row=0, column=0, sticky="nsew")
        self.columnconfigure(0, weight=1)
        self.rowconfigure(0, weight=1)
        root.columnconfigure(0, weight=1)
        root.rowconfigure(3, weight=1)

        radar_frame = ttk.LabelFrame(root, text="雷达设置")
        radar_frame.grid(row=0, column=0, sticky="ew")
        radar_frame.columnconfigure(1, weight=1)

        ttk.Label(radar_frame, text="config_file:").grid(row=0, column=0, sticky="w", padx=6, pady=4)
        self.config_combo = ttk.Combobox(
            radar_frame,
            textvariable=self.config_var,
            values=self._detect_config_files(),
            state="readonly",
            width=24,
        )
        self.config_combo.grid(row=0, column=1, sticky="ew", padx=(4, 6), pady=4)

        ttk.Label(radar_frame, text="PCD 地图:").grid(row=1, column=0, sticky="w", padx=6, pady=4)
        self.pcd_combo = ttk.Combobox(
            radar_frame,
            textvariable=self.pcd_var,
            values=[],
            state="readonly",
            width=48,
        )
        self.pcd_combo.grid(row=1, column=1, sticky="ew", padx=(4, 6), pady=4)
        ttk.Button(radar_frame, text="刷新地图", command=self._refresh_pcd_files).grid(
            row=1,
            column=2,
            sticky="ew",
            padx=(0, 6),
            pady=4,
        )

        ttk.Label(radar_frame, text="标定文件:").grid(row=2, column=0, sticky="w", padx=6, pady=4)
        self.calibration_combo = ttk.Combobox(
            radar_frame,
            textvariable=self.calibration_var,
            values=[],
            state="readonly",
            width=48,
        )
        self.calibration_combo.grid(row=2, column=1, sticky="ew", padx=(4, 6), pady=4)
        ttk.Button(radar_frame, text="刷新标定", command=self._refresh_calibration_files).grid(
            row=2,
            column=2,
            sticky="ew",
            padx=(0, 6),
            pady=4,
        )

        lidar_ok = (LIDAR_WS / "install" / "setup.bash").exists()
        livox_ok = (LIVOX_WS / "install" / "setup.bash").exists()
        lio_ok = (FAST_LIO_WS / "install" / "setup.bash").exists()
        lidar_mark = "OK" if lidar_ok else "Missing"
        livox_mark = "OK" if livox_ok else "Missing"
        lio_mark = "OK" if lio_ok else "Missing"
        self.radar_status_label = ttk.Label(
            radar_frame,
            text=f"unitree {lidar_mark}    livox {livox_mark}    fast_lio {lio_mark}",
        )
        self.radar_status_label.grid(row=3, column=0, columnspan=3, sticky="w", padx=6, pady=(0, 4))

        self.mapping_save_label = ttk.Label(radar_frame, text="建图保存: 未开始")
        self.mapping_save_label.grid(row=4, column=0, columnspan=3, sticky="w", padx=6, pady=(0, 4))

        race_frame = ttk.LabelFrame(root, text="赛事逻辑")
        race_frame.grid(row=1, column=0, sticky="ew", pady=(4, 0))
        race_frame.columnconfigure(7, weight=1)

        ttk.Radiobutton(
            race_frame,
            text="obstacle",
            variable=self.race_logic_var,
            value="obstacle",
        ).grid(row=0, column=0, sticky="w", padx=6, pady=4)
        ttk.Radiobutton(
            race_frame,
            text="mission",
            variable=self.race_logic_var,
            value="mission",
        ).grid(row=0, column=1, sticky="w", padx=6, pady=4)
        ttk.Label(race_frame, text="恢复:").grid(row=0, column=2, sticky="e", padx=(6, 2), pady=4)
        ttk.Combobox(
            race_frame,
            textvariable=self.mission_resume_event_var,
            values=("ack", "grabbed", "completed"),
            state="readonly",
            width=10,
        ).grid(row=0, column=3, sticky="w", padx=(2, 6), pady=4)
        ttk.Label(race_frame, text="半径:").grid(row=0, column=4, sticky="e", padx=(6, 2), pady=4)
        ttk.Entry(race_frame, textvariable=self.mission_task_radius_var, width=8).grid(
            row=0,
            column=5,
            sticky="w",
            padx=(2, 6),
            pady=4,
        )
        ttk.Label(race_frame, text="重试:").grid(row=0, column=6, sticky="e", padx=(6, 2), pady=4)
        ttk.Entry(race_frame, textvariable=self.mission_arm_retry_period_var, width=8).grid(
            row=0,
            column=7,
            sticky="w",
            padx=(2, 6),
            pady=4,
        )

        action_frame = ttk.Frame(root)
        action_frame.grid(row=2, column=0, sticky="ew", pady=(6, 4))
        action_frame.columnconfigure(5, weight=1)

        self.start_core_button = ttk.Button(action_frame, text="启动 Core", command=self.start_core)
        self.start_core_button.grid(row=0, column=0, padx=(0, 8))
        self.start_mapping_button = ttk.Button(action_frame, text="开始建图", command=self.start_mapping)
        self.start_mapping_button.grid(row=0, column=1, padx=(0, 8))
        self.finish_mapping_button = ttk.Button(
            action_frame,
            text="完成建图",
            command=self.finish_mapping,
            state=tk.DISABLED,
        )
        self.finish_mapping_button.grid(row=0, column=2, padx=(0, 8))
        self.stop_button = ttk.Button(action_frame, text="停止", command=self.stop_launch, state=tk.DISABLED)
        self.stop_button.grid(row=0, column=3, padx=(0, 8))
        self.status_label = ttk.Label(action_frame, text="未启动")
        self.status_label.grid(row=0, column=5, sticky="e")

        log_frame = ttk.LabelFrame(root, text="日志")
        log_frame.grid(row=3, column=0, sticky="nsew")
        log_frame.columnconfigure(0, weight=1)
        log_frame.rowconfigure(0, weight=1)

        self.log_text = tk.Text(log_frame, height=8, wrap="word", state=tk.DISABLED)
        self.log_text.grid(row=0, column=0, sticky="nsew")
        scrollbar = ttk.Scrollbar(log_frame, orient="vertical", command=self.log_text.yview)
        scrollbar.grid(row=0, column=1, sticky="ns")
        self.log_text.configure(yscrollcommand=scrollbar.set)

    @staticmethod
    def _default_config_file() -> str:
        configs = NavigationCoreLauncher._detect_config_files()
        return "unilidar.yaml" if "unilidar.yaml" in configs else configs[0]

    @staticmethod
    def _detect_config_files() -> list[str]:
        if not FAST_LIO_CONFIG_DIR.exists():
            return ["unilidar.yaml"]
        configs = sorted(p.name for p in FAST_LIO_CONFIG_DIR.glob("*.yaml"))
        return configs if configs else ["unilidar.yaml"]

    @staticmethod
    def _default_calibration_file() -> str:
        files = NavigationCoreLauncher._detect_calibration_files()
        return DEFAULT_CALIBRATION_FILE if DEFAULT_CALIBRATION_FILE in files else NO_CALIBRATION_LABEL

    def _refresh_pcd_files(self, *, select_first: bool = False) -> None:
        values = self._detect_pcd_files()
        current = self.pcd_var.get()
        self.pcd_combo.configure(values=values)
        if values and (select_first or current not in values):
            self.pcd_var.set(values[0])
        elif not values:
            self.pcd_var.set("")
        self.append_log(f"[maps] 找到 {len(values)} 个 PCD 地图。\n")

    def _refresh_calibration_files(self, *, select_default: bool = False) -> None:
        values = [NO_CALIBRATION_LABEL, *self._detect_calibration_files()]
        current = self.calibration_var.get()
        self.calibration_combo.configure(values=values)
        if values and (select_default or current not in values):
            self.calibration_var.set(DEFAULT_CALIBRATION_FILE if DEFAULT_CALIBRATION_FILE in values else NO_CALIBRATION_LABEL)
        self.append_log(f"[calibration] 找到 {len(values) - 1} 个标定文件。\n")

    @staticmethod
    def _detect_pcd_files() -> list[str]:
        if not FAST_LIO_MAP_ROOT.exists():
            return []
        values: list[str] = []
        for path in sorted(FAST_LIO_MAP_ROOT.rglob("*.pcd")):
            try:
                values.append(str(path.relative_to(FAST_LIO_MAP_ROOT)))
            except ValueError:
                values.append(str(path))
        return values

    @staticmethod
    def _detect_calibration_files() -> list[str]:
        files: set[str] = set()
        for calibration_dir in NavigationCoreLauncher._calibration_dirs():
            for path in calibration_dir.iterdir():
                if path.is_file() and path.suffix in {".yaml", ".yml"}:
                    files.add(path.name)
        return sorted(files)

    def append_log(self, line: str) -> None:
        self.log_text.configure(state=tk.NORMAL)
        self.log_text.insert(tk.END, line)
        self.log_text.see(tk.END)
        self.log_text.configure(state=tk.DISABLED)

    def start_core(self) -> None:
        if self.process is not None:
            messagebox.showinfo("Navigation Core Launcher", "当前已经有启动进程。", parent=self)
            return

        local_setup, workspace = detect_workspace_setup()
        if local_setup is None:
            messagebox.showerror(
                "Navigation Core Launcher",
                "找不到 workspace setup 文件。请先在包含 navigation 的 workspace 里执行 colcon build。",
                parent=self,
            )
            return

        pcd_path = self._selected_pcd_path()
        if pcd_path is None:
            return
        calibration_path = self._selected_calibration_path()
        if calibration_path is None:
            return

        try:
            self._check_radar_workspaces()
            fast_lio_config = self._write_fast_lio_temp_config(
                config_file=self.config_var.get(),
                pcd_path=pcd_path,
                save_enabled=False,
                save_path=pcd_path,
                suffix="core",
            )
            command = self._build_core_command(local_setup, fast_lio_config, calibration_path)
        except ValueError as exc:
            messagebox.showerror("Navigation Core Launcher", str(exc), parent=self)
            return
        except OSError as exc:
            messagebox.showerror("Navigation Core Launcher", f"生成临时配置失败:\n{exc}", parent=self)
            return

        self._start_process(command, workspace, "core")

    def start_mapping(self) -> None:
        if self.process is not None:
            messagebox.showinfo("Navigation Core Launcher", "当前已经有启动进程。", parent=self)
            return

        workspace = FAST_LIO_WS
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        save_path = FAST_LIO_DEFAULT_SAVE_DIR / f"map_{timestamp}.pcd"
        self.mapping_output_path = save_path

        try:
            self._check_radar_workspaces()
            FAST_LIO_DEFAULT_SAVE_DIR.mkdir(parents=True, exist_ok=True)
            fast_lio_config = self._write_fast_lio_temp_config(
                config_file=self.config_var.get(),
                pcd_path=Path(""),
                save_enabled=True,
                save_path=save_path,
                suffix="mapping",
            )
            command = self._build_mapping_command(fast_lio_config)
        except ValueError as exc:
            messagebox.showerror("Navigation Core Launcher", str(exc), parent=self)
            return
        except OSError as exc:
            messagebox.showerror("Navigation Core Launcher", f"生成建图配置失败:\n{exc}", parent=self)
            return

        self.mapping_save_label.configure(text=f"建图保存: {self._display_path(save_path)}")
        self._start_process(command, workspace, "mapping")

    def finish_mapping(self) -> None:
        if self.running_mode != "mapping" or self.process is None:
            messagebox.showinfo("Navigation Core Launcher", "当前没有运行中的建图流程。", parent=self)
            return

        self.finish_mapping_button.configure(state=tk.DISABLED)
        self.status_label.configure(text="正在保存地图")
        thread = threading.Thread(target=self._call_map_save_service, daemon=True)
        thread.start()

    def _call_map_save_service(self) -> None:
        command = self._build_map_save_command()
        try:
            result = subprocess.run(
                ["bash", "-lc", command],
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                timeout=MAP_SAVE_TIMEOUT + 5,
                check=False,
            )
            output = result.stdout or ""
            self.after(0, self._map_save_finished, result.returncode, output)
        except (OSError, subprocess.TimeoutExpired) as exc:
            self.after(0, self._map_save_failed, str(exc))

    def _map_save_finished(self, return_code: int, output: str) -> None:
        self.append_log(f"$ {self._build_map_save_command()}\n")
        self.append_log(output)
        if return_code == 0:
            self.status_label.configure(text="地图已保存，建图仍在运行")
            messagebox.showinfo(
                "Navigation Core Launcher",
                f"地图保存完成:\n{self._display_path(self.mapping_output_path)}",
                parent=self,
            )
            self._refresh_pcd_files()
        else:
            self.status_label.configure(text="地图保存失败")
            messagebox.showerror("Navigation Core Launcher", "调用 /map_save 失败，请查看日志。", parent=self)
        if self.running_mode == "mapping" and self.process is not None:
            self.finish_mapping_button.configure(state=tk.NORMAL)

    def _map_save_failed(self, message: str) -> None:
        self.append_log(f"\n[map_save failed: {message}]\n")
        self.status_label.configure(text="地图保存失败")
        messagebox.showerror("Navigation Core Launcher", f"调用 /map_save 失败:\n{message}", parent=self)
        if self.running_mode == "mapping" and self.process is not None:
            self.finish_mapping_button.configure(state=tk.NORMAL)

    def _build_core_command(self, local_setup: Path, fast_lio_config: Path, calibration_path: str) -> str:
        parts = self._base_shell_parts()
        parts.append("trap 'for pid in $(jobs -pr); do kill \"$pid\" 2>/dev/null || true; done' EXIT")
        parts.extend(self._build_radar_pipeline_commands(fast_lio_config, rviz=False))
        parts.append(f"source {shlex.quote(str(local_setup))}")

        mission_task_radius = self._selected_positive_float(self.mission_task_radius_var, "0.40")
        mission_arm_retry_period = self._selected_positive_float(self.mission_arm_retry_period_var, "1.0")
        launch_args = [
            "ros2",
            "launch",
            "navigation",
            "navigation.launch.py",
            "navigation_executable:=navigation_core",
            "node_role:=core",
            "source:=radar",
            "show_window:=false",
            "sim_odom_topic:=/odom",
            "radar_odom_topic:=/Odometry",
            "radar_calibration_topic:=/Odometry",
            f"radar_calibration_file:={calibration_path}",
            "ui_size:=10",
            "map_padding_px:=20.0",
            "panel_collapsed:=true",
            f"race_logic:={self.race_logic_var.get()}",
            f"mission_resume_event:={self.mission_resume_event_var.get()}",
            f"mission_task_radius:={mission_task_radius}",
            f"mission_arm_retry_period:={mission_arm_retry_period}",
            "arm_mission_service:=/arm/mission_event",
            "navigation_arm_event_service:=/navigation/arm_event",
        ]
        parts.append("exec " + " ".join(shlex.quote(arg) for arg in launch_args))
        return " && ".join(parts)

    def _build_mapping_command(self, fast_lio_config: Path) -> str:
        parts = self._base_shell_parts()
        parts.append("trap 'for pid in $(jobs -pr); do kill \"$pid\" 2>/dev/null || true; done' EXIT")
        parts.extend(self._build_radar_pipeline_commands(fast_lio_config, rviz=True))
        parts.append("tail -f /dev/null")
        return " && ".join(parts)

    def _base_shell_parts(self) -> list[str]:
        parts: list[str] = ["set -e"]
        ros_setup = detect_ros_setup()
        if ros_setup is not None:
            parts.append(f"source {shlex.quote(str(ros_setup))}")
        if UNITREE_CYCLONEDDS_SETUP.exists():
            parts.append(f"source {shlex.quote(str(UNITREE_CYCLONEDDS_SETUP))}")
        return parts

    def _build_radar_pipeline_commands(self, fast_lio_config: Path, *, rviz: bool) -> list[str]:
        config_file = self.config_var.get()
        lidar_ws, launch_args = self._resolve_lidar_driver(config_file)
        lidar_setup = Path(lidar_ws) / "install" / "setup.bash"
        lio_setup = FAST_LIO_WS / "install" / "setup.bash"
        lidar_topics = self._fast_lio_input_topics(config_file)

        lidar_source_path = self._tilde(lidar_setup)
        lio_source_path = self._tilde(lio_setup)
        fast_lio_config_dir = fast_lio_config.parent
        fast_lio_config_file = fast_lio_config.name

        commands = [
            f"echo {shlex.quote('[self-check] 启动雷达驱动...')}",
            f"{{ (source {lidar_source_path} && "
            f"{' '.join(shlex.quote(arg) for arg in launch_args)}) & "
            f"sleep {LIDAR_INIT_DELAY}; }}",
        ]

        for label, topic in lidar_topics:
            commands.append(f"echo {shlex.quote(f'[self-check] 等待雷达 {label}: {topic}')}")
            commands.append(
                f"if ! {self._topic_echo_once_command(lidar_setup, topic, LIDAR_TOPIC_TIMEOUT)}; "
                f"then echo {shlex.quote(self._self_check_marker('FAIL', f'雷达自检失败：{label} {topic} 在 {LIDAR_TOPIC_TIMEOUT}s 内没有收到消息'))}; "
                "exit 1; fi"
            )

        commands.extend(
            [
                f"echo {shlex.quote('[self-check] 雷达输入正常，启动 FastLIO...')}",
                f"{{ (source {lio_source_path} && ros2 launch fast_lio mapping.launch.py "
                f"config_path:={shlex.quote(str(fast_lio_config_dir))} "
                f"config_file:={shlex.quote(fast_lio_config_file)} "
                f"rviz:={'true' if rviz else 'false'}) & sleep {FAST_LIO_INIT_DELAY}; }}",
                f"echo {shlex.quote(f'[self-check] 等待 FastLIO 输出: {FAST_LIO_ODOM_TOPIC}')}",
                f"if ! {self._topic_echo_once_command(lio_setup, FAST_LIO_ODOM_TOPIC, FAST_LIO_TOPIC_TIMEOUT)}; "
                f"then echo {shlex.quote(self._self_check_marker('FAIL', f'FastLIO 自检失败：{FAST_LIO_ODOM_TOPIC} 在 {FAST_LIO_TOPIC_TIMEOUT}s 内没有收到消息'))}; "
                "exit 1; fi",
                f"echo {shlex.quote(self._self_check_marker('OK', '雷达和 FastLIO 自检通过'))}",
            ]
        )
        return commands

    def _build_map_save_command(self) -> str:
        parts = self._base_shell_parts()
        lio_setup = FAST_LIO_WS / "install" / "setup.bash"
        parts.append(f"source {shlex.quote(str(lio_setup))}")
        parts.append(f"timeout {MAP_SAVE_TIMEOUT}s ros2 service call /map_save std_srvs/srv/Trigger '{{}}'")
        return " && ".join(parts)

    def _write_fast_lio_temp_config(
        self,
        *,
        config_file: str,
        pcd_path: Path,
        save_enabled: bool,
        save_path: Path,
        suffix: str,
    ) -> Path:
        source_path = FAST_LIO_CONFIG_DIR / config_file
        if not source_path.exists():
            raise ValueError(f"找不到 FAST-LIO config: {source_path}")

        text = source_path.read_text(encoding="utf-8")
        path_pcd = "" if str(pcd_path) == "." else str(pcd_path)
        replacements = {
            "map_file_path": str(save_path),
            "path_pcd": path_pcd,
            "pcd_save_en": "true" if save_enabled else "false",
        }
        text = self._replace_yaml_scalar(text, "map_file_path", self._yaml_quote(replacements["map_file_path"]))
        text = self._replace_yaml_scalar(text, "path_pcd", self._yaml_quote(replacements["path_pcd"]))
        text = self._replace_yaml_scalar(text, "pcd_save_en", replacements["pcd_save_en"])

        TEMP_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        stem = Path(config_file).stem
        output = TEMP_CONFIG_DIR / f"{stem}_{suffix}.yaml"
        output.write_text(text, encoding="utf-8")
        self.append_log(f"[config] FAST-LIO 临时配置: {output}\n")
        self.append_log(f"[config] common.path_pcd: {path_pcd or '<empty>'}\n")
        self.append_log(f"[config] map_file_path: {save_path}\n")
        return output

    @staticmethod
    def _replace_yaml_scalar(text: str, key: str, value: str) -> str:
        pattern = re.compile(rf"^(\s*{re.escape(key)}\s*:\s*)(.*)$", re.MULTILINE)
        next_text, count = pattern.subn(rf"\g<1>{value}", text, count=1)
        if count == 0:
            raise ValueError(f"FAST-LIO config 缺少字段: {key}")
        return next_text

    @staticmethod
    def _yaml_quote(value: str) -> str:
        escaped = value.replace("\\", "\\\\").replace('"', '\\"')
        return f'"{escaped}"'

    def _check_radar_workspaces(self) -> None:
        config_file = self.config_var.get()
        lidar_ws, _ = self._resolve_lidar_driver(config_file)
        missing = []
        if not (Path(lidar_ws) / "install" / "setup.bash").exists():
            missing.append(str(lidar_ws))
        if not (FAST_LIO_WS / "install" / "setup.bash").exists():
            missing.append(str(FAST_LIO_WS))
        if missing:
            raise ValueError("雷达工作空间缺少 install/setup.bash:\n" + "\n".join(f"  - {p}" for p in missing))

    def _selected_pcd_path(self) -> Path | None:
        selected = self.pcd_var.get().strip()
        if not selected:
            messagebox.showerror("Navigation Core Launcher", "没有可用的 PCD 地图。", parent=self)
            return None
        path = Path(selected)
        if not path.is_absolute():
            path = FAST_LIO_MAP_ROOT / selected
        if not path.exists():
            messagebox.showerror("Navigation Core Launcher", f"PCD 地图不存在:\n{path}", parent=self)
            return None
        return path

    def _selected_calibration_path(self) -> str | None:
        selected = self.calibration_var.get().strip()
        if not selected or selected == NO_CALIBRATION_LABEL:
            return str(NO_CALIBRATION_PATH)
        path = Path(selected)
        if not path.is_absolute():
            calibration_dirs = self._calibration_dirs()
            if not calibration_dirs:
                messagebox.showerror("Navigation Core Launcher", "找不到 calibration/cali_params 目录。", parent=self)
                return None
            path = next((candidate / selected for candidate in calibration_dirs if (candidate / selected).exists()), calibration_dirs[0] / selected)
        if not path.exists():
            messagebox.showerror("Navigation Core Launcher", f"标定文件不存在:\n{path}", parent=self)
            return None
        return f"package://navigation/config/calibration/cali_params/{path.name}"

    @staticmethod
    def _calibration_dirs() -> list[Path]:
        script_path = Path(__file__).resolve()
        dirs: list[Path] = []
        for parent in script_path.parents:
            candidates = [
                parent / "config" / "calibration" / "cali_params",
                parent / "share" / "navigation" / "config" / "calibration" / "cali_params",
                parent / "navigation" / "share" / "navigation" / "config" / "calibration" / "cali_params",
                parent / "install" / "navigation" / "share" / "navigation" / "config" / "calibration" / "cali_params",
            ]
            for candidate in candidates:
                if candidate.exists() and candidate not in dirs:
                    dirs.append(candidate)
        return dirs

    @staticmethod
    def _tilde(path: Path) -> str:
        home = Path.home()
        try:
            return "~/" + str(path.relative_to(home))
        except ValueError:
            return str(path)

    @staticmethod
    def _self_check_marker(status: str, message: str) -> str:
        return f"{SELF_CHECK_MARKER}{status}:{message}"

    @staticmethod
    def _topic_echo_once_command(setup_file: Path, topic: str, timeout_seconds: int) -> str:
        inner = (
            f"source {shlex.quote(str(setup_file))} && "
            "while true; do "
            f"timeout 2s ros2 topic echo {shlex.quote(topic)} --once >/dev/null 2>&1 && exit 0; "
            "sleep 0.5; "
            "done"
        )
        return f"timeout {timeout_seconds}s bash -lc {shlex.quote(inner)}"

    @staticmethod
    def _extract_yaml_topic(text: str, key: str) -> str | None:
        match = re.search(rf"^\s*{re.escape(key)}\s*:\s*['\"]?([^'\"\s#]+)", text, re.MULTILINE)
        return match.group(1) if match else None

    def _fast_lio_input_topics(self, config_file: str) -> list[tuple[str, str]]:
        defaults = {
            "mid360": [("lidar", "/livox/lidar"), ("imu", "/livox/imu")],
            "unilidar": [("lidar", "/unilidar/cloud"), ("imu", "/unilidar/imu")],
        }
        topics = defaults["mid360"] if config_file.startswith("mid360") else defaults["unilidar"]

        config_path = FAST_LIO_CONFIG_DIR / config_file
        if not config_path.exists():
            return topics

        try:
            text = config_path.read_text(encoding="utf-8")
        except OSError:
            return topics

        lid_topic = self._extract_yaml_topic(text, "lid_topic") or topics[0][1]
        imu_topic = self._extract_yaml_topic(text, "imu_topic") or topics[1][1]
        return [("lidar", lid_topic), ("imu", imu_topic)]

    @staticmethod
    def _resolve_lidar_driver(config_file: str) -> tuple[str, list[str]]:
        if config_file.startswith("mid360"):
            return (
                str(LIVOX_WS),
                ["ros2", "launch", "livox_ros_driver2", "msg_MID360_launch.py"],
            )
        if config_file.startswith("unilidar"):
            return (
                str(LIDAR_WS),
                [
                    "ros2",
                    "run",
                    "unitree_lidar_ros2",
                    "unitree_lidar_ros2_node",
                    "--ros-args",
                    "-p",
                    "initialize_type:=1",
                    "-p",
                    "work_mode:=8",
                    "-p",
                    "use_system_timestamp:=true",
                    "-p",
                    "range_min:=0.0",
                    "-p",
                    "range_max:=100.0",
                    "-p",
                    "cloud_scan_num:=18",
                    "-p",
                    "serial_port:=/dev/ttyACM0",
                    "-p",
                    "baudrate:=4000000",
                    "-p",
                    "lidar_port:=6101",
                    "-p",
                    "lidar_ip:=192.168.1.62",
                    "-p",
                    "local_port:=6201",
                    "-p",
                    "local_ip:=192.168.1.2",
                    "-p",
                    "cloud_frame:=unilidar_lidar",
                    "-p",
                    "cloud_topic:=unilidar/cloud",
                    "-p",
                    "imu_frame:=unilidar_imu",
                    "-p",
                    "imu_topic:=unilidar/imu",
                ],
            )
        raise ValueError(
            f"不支持该 config_file 对应的雷达驱动: {config_file}\n"
            "config_file 必须以 mid360 或 unilidar 开头。"
        )

    @staticmethod
    def _selected_positive_float(value_var: tk.StringVar, fallback: str) -> str:
        try:
            value = float(value_var.get())
            if value <= 0.0:
                raise ValueError
        except ValueError:
            value_var.set(fallback)
            return fallback
        return f"{value:.3f}"

    @staticmethod
    def _display_path(path: Path | None) -> str:
        if path is None:
            return "未开始"
        home = Path.home()
        try:
            return "~/" + str(path.relative_to(home))
        except ValueError:
            return str(path)

    def _start_process(self, command: str, workspace: Path, mode: str) -> None:
        self.append_log(f"$ {command}\n")
        try:
            self.process = subprocess.Popen(
                ["bash", "-lc", command],
                cwd=str(workspace),
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                bufsize=1,
                preexec_fn=os.setsid,
            )
            self.process_pgid = os.getpgid(self.process.pid)
        except OSError as exc:
            self.process = None
            self.process_pgid = None
            messagebox.showerror("Navigation Core Launcher", f"启动失败:\n{exc}", parent=self)
            return

        self.running_mode = mode
        self.self_check_failed = False
        self.close_after_stop = False
        self.start_core_button.configure(state=tk.DISABLED)
        self.start_mapping_button.configure(state=tk.DISABLED)
        self.stop_button.configure(state=tk.NORMAL)
        self.finish_mapping_button.configure(state=tk.NORMAL if mode == "mapping" else tk.DISABLED)
        self.status_label.configure(text="自检中")
        self.reader_thread = threading.Thread(target=self._read_process_output, daemon=True)
        self.reader_thread.start()

    def _read_process_output(self) -> None:
        process = self.process
        assert process is not None
        assert process.stdout is not None
        for line in process.stdout:
            try:
                self.after(0, self._handle_process_output_line, line)
            except tk.TclError:
                return
        return_code = process.wait()
        try:
            self.after(0, self._process_finished, process, return_code)
        except tk.TclError:
            pass

    def _handle_process_output_line(self, line: str) -> None:
        self.append_log(line)
        if SELF_CHECK_MARKER not in line:
            return

        marker = line.split(SELF_CHECK_MARKER, 1)[1].strip()
        status, _, message = marker.partition(":")
        if status == "OK":
            text = "建图中" if self.running_mode == "mapping" else "自检通过，Core 运行中"
            self.status_label.configure(text=text)
            messagebox.showinfo("Navigation Core Launcher", message, parent=self)
        elif status == "FAIL":
            self.self_check_failed = True
            self.status_label.configure(text="自检失败")
            messagebox.showerror("Navigation Core Launcher", message, parent=self)

    def _process_finished(self, process: subprocess.Popen[str], return_code: int) -> None:
        if self.process is not process:
            return
        pgid = self.process_pgid
        self.append_log(f"\n[process exited with code {return_code}]\n")
        self._cleanup_process_group(pgid)
        self.process = None
        self.process_pgid = None
        self.running_mode = None
        self.start_core_button.configure(state=tk.NORMAL)
        self.start_mapping_button.configure(state=tk.NORMAL)
        self.finish_mapping_button.configure(state=tk.DISABLED)
        self.stop_button.configure(state=tk.DISABLED)
        self.status_label.configure(text="自检失败" if self.self_check_failed else "已退出")
        if self.close_after_stop:
            self.status_label.configure(text="正在退出")
            self.after(1200, self.destroy)

    def _signal_process_group(self, pgid: int | None, sig: signal.Signals) -> bool:
        if pgid is None:
            return False
        try:
            os.killpg(pgid, sig)
            return True
        except ProcessLookupError:
            return False
        except PermissionError as exc:
            self.append_log(f"\n[failed to send {sig.name} to process group {pgid}: {exc}]\n")
            return False

    def _process_group_alive(self, pgid: int | None) -> bool:
        if pgid is None:
            return False
        try:
            os.killpg(pgid, 0)
            return True
        except ProcessLookupError:
            return False
        except PermissionError:
            return True

    def _cleanup_process_group(self, pgid: int | None) -> None:
        if not self._process_group_alive(pgid):
            return
        self.append_log("\n[cleaning remaining launch process group]\n")
        self._signal_process_group(pgid, signal.SIGTERM)
        self.after(1000, lambda: self._kill_process_group_if_alive(pgid))

    def stop_launch(self, *, close_after_stop: bool = False) -> None:
        if self.process is None:
            return
        process = self.process
        pgid = self.process_pgid
        self.close_after_stop = self.close_after_stop or close_after_stop
        self.append_log("\n[stopping launch process]\n")
        self.finish_mapping_button.configure(state=tk.DISABLED)
        self.stop_button.configure(state=tk.DISABLED)
        self.status_label.configure(text="正在停止并退出" if self.close_after_stop else "正在停止")
        self._signal_process_group(pgid, signal.SIGINT)
        self.after(4000, lambda: self._terminate_if_needed(process, pgid))

    def _terminate_if_needed(self, process: subprocess.Popen[str], pgid: int | None) -> None:
        if self.process is not process or process.poll() is not None:
            return
        self.append_log("\n[launch process still running, sending SIGTERM]\n")
        self._signal_process_group(pgid, signal.SIGTERM)
        self.after(3000, lambda: self._kill_if_needed(process, pgid))

    def _kill_if_needed(self, process: subprocess.Popen[str], pgid: int | None) -> None:
        if self.process is not process or process.poll() is not None:
            return
        self.append_log("\n[launch process still running, sending SIGKILL]\n")
        self._signal_process_group(pgid, signal.SIGKILL)

    def _kill_process_group_if_alive(self, pgid: int | None) -> None:
        if not self._process_group_alive(pgid):
            return
        self.append_log("\n[remaining launch process group still alive, sending SIGKILL]\n")
        self._signal_process_group(pgid, signal.SIGKILL)

    def _on_close(self) -> None:
        if self.process is not None:
            if self.close_after_stop:
                return
            if not messagebox.askyesno(
                "Navigation Core Launcher",
                "启动进程还在运行，是否停止并退出？",
                parent=self,
            ):
                return
            self.stop_launch(close_after_stop=True)
            return
        self.destroy()


if __name__ == "__main__":
    app = NavigationCoreLauncher()
    app.mainloop()
