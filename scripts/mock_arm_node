#!/usr/bin/env python3
"""Mock mechanical arm node for mission-race navigation testing."""

from __future__ import annotations

import functools

import rclpy
from navigation.srv import StringCommand
from rclpy.node import Node
from std_srvs.srv import Trigger


class MockArmNode(Node):
    def __init__(self) -> None:
        super().__init__("mock_arm_node")
        self.arm_mission_service = self.declare_parameter(
            "arm_mission_service",
            "/arm/mission_event",
        ).value
        self.navigation_arm_event_service = self.declare_parameter(
            "navigation_arm_event_service",
            "/navigation/arm_event",
        ).value
        self.grabbed_delay_s = float(self.declare_parameter("grabbed_delay_s", 1.0).value)
        self.completed_delay_s = float(self.declare_parameter("completed_delay_s", 1.0).value)

        self.event_client = self.create_client(StringCommand, self.navigation_arm_event_service)
        self.arrived_service = self.create_service(
            Trigger,
            self.arm_mission_service,
            self.handle_arrived,
        )
        self.pending_timers = set()
        self.pending_futures = set()
        self.sequence_index = 0

        self.get_logger().info(
            f"Mock arm ready. service={self.arm_mission_service}, "
            f"nav_event={self.navigation_arm_event_service}"
        )

    def handle_arrived(
        self,
        request: Trigger.Request,
        response: Trigger.Response,
    ) -> Trigger.Response:
        _ = request
        self.sequence_index += 1
        sequence = self.sequence_index
        self.get_logger().info(f"[{sequence}] 已收到nav到达触发请求")

        response.success = True
        response.message = "received"
        self.get_logger().info(f"[{sequence}] 已经回复nav: success=true message=received")
        self.schedule_event("grabbed", self.grabbed_delay_s, sequence)
        self.schedule_event("completed", self.grabbed_delay_s + self.completed_delay_s, sequence)
        return response

    def schedule_event(self, event: str, delay_s: float, sequence: int) -> None:
        timer = None

        def callback() -> None:
            self.fire_event_once(timer, event, sequence)

        timer = self.create_timer(max(0.0, delay_s), callback)
        self.pending_timers.add(timer)

    def fire_event_once(self, timer, event: str, sequence: int) -> None:
        self.pending_timers.discard(timer)
        timer.cancel()
        self.destroy_timer(timer)
        self.send_nav_event(event, sequence)

    def send_nav_event(self, event: str, sequence: int) -> None:
        if not self.event_client.service_is_ready():
            self.get_logger().warn(
                f"Navigation arm event service unavailable; dropping {event} for sequence {sequence}."
            )
            return

        if event == "grabbed":
            self.get_logger().info(f"[{sequence}] 已经抓取")
        elif event == "completed":
            self.get_logger().info(f"[{sequence}] 已经完成")

        request = StringCommand.Request()
        request.message = event
        future = self.event_client.call_async(request)
        self.pending_futures.add(future)
        future.add_done_callback(functools.partial(self.handle_event_response, event, sequence))
        if event == "grabbed":
            self.get_logger().info(f"[{sequence}] 已发送已抓取给nav: grabbed")
        elif event == "completed":
            self.get_logger().info(f"[{sequence}] 已发送已经完成给nav: completed")

    def handle_event_response(self, event: str, sequence: int, future) -> None:
        self.pending_futures.discard(future)
        try:
            response = future.result()
        except Exception as exc:  # noqa: BLE001 - report ROS callback errors to the log.
            self.get_logger().error(f"Failed to send {event} for sequence {sequence}: {exc}")
            return

        label = "已抓取" if event == "grabbed" else "已经完成"
        if response.success:
            self.get_logger().info(f"[{sequence}] {label}已收到nav回信: {response.message}")
            return

        self.get_logger().warn(f"[{sequence}] {label}收到nav拒绝: {response.message}")


def main() -> None:
    rclpy.init()
    node = MockArmNode()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
