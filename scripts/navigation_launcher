            mode_frame,
            text="MuJoCo + midware",
            variable=self.launch_mode_var,
            value="mujoco_navigation",
        )
        self.mujoco_mode.grid(row=0, column=1, sticky="w", padx=6, pady=4)

        # ---- 雷达设置 ----
        self.radar_frame = ttk.LabelFrame(root, text="雷达设置")
        self.radar_frame.grid(row=1, column=0, sticky="ew", padx=(0, 3), pady=(4, 0))
        self.radar_frame.columnconfigure(1, weight=1)

        ttk.Label(self.radar_frame, text="config_file:").grid(
