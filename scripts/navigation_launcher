        size_frame = ttk.LabelFrame(root, text="UI 大小")
        size_frame.grid(row=2, column=0, sticky="ew", columnspan=2, pady=(4, 0))
        size_frame.columnconfigure(1, weight=1)

        ttk.Label(size_frame, text="导航界面大小 5-15").grid(
            row=0,
            column=0,
            sticky="w",
