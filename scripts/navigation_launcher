            self.radar_frame,
            text=f"  unitree {lidar_mark}    livox {livox_mark}    fast_lio {lio_mark}",
        )
        self.radar_status_label.grid(row=1, column=0, columnspan=2, sticky="w", padx=6, pady=(0, 4))

