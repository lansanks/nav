            command=self._sync_mode_state,
        ).grid(row=0, column=1, sticky="w", padx=6, pady=4)
        ttk.Radiobutton(
            node_frame,
            text="remote UI",
            variable=self.node_mode_var,
            value="remote_ui",
            command=self._sync_mode_state,
