#!/usr/bin/env python3
"""Small desktop launcher for the navigation ROS 2 launch file."""

from __future__ import annotations

import glob
import os
import re
import shlex
import signal
import subprocess
import threading
import tkinter as tk
from pathlib import Path
from tkinter import messagebox, ttk


UNITREE_CYCLONEDDS_SETUP = Path.home() / "unitree_ros2" / "cyclonedds_ws" / "install" / "setup.bash"

LIDAR_WS = Path.home() / "lidar" / "radar" / "unilidar" / "unitree_lidar_ros2"
LIVOX_WS = Path.home() / "lidar" / "radar" / "livox" / "livox_ws"
FAST_LIO_WS = Path.home() / "lidar" / "lio" / "fast_lio_ws"
LIDAR_INIT_DELAY = 2
FAST_LIO_INIT_DELAY = 2
LIDAR_TOPIC_TIMEOUT = 10
FAST_LIO_TOPIC_TIMEOUT = 12
FAST_LIO_ODOM_TOPIC = "/Odometry"
SELF_CHECK_MARKER = "__NAVIGATION_SELF_CHECK__:"

FAST_LIO_CONFIG_DIR = FAST_LIO_WS / "src" / "FAST_LIO_ROS2" / "config"


def detect_workspace_setup() -> tuple[Path | None, Path]:
    script_path = Path(__file__).resolve()
    for parent in script_path.parents:
        setup_candidates = [
            parent / "install" / "setup.bash",
            parent / "install" / "local_setup.bash",
            parent / "setup.bash",
            parent / "local_setup.bash",
        ]
        for setup in setup_candidates:
            if setup.exists():
                workspace = setup.parent.parent if setup.parent.name == "install" else setup.parent
                return setup, workspace

    for prefix_text in os.environ.get("AMENT_PREFIX_PATH", "").split(os.pathsep):
        if not prefix_text:
            continue
        prefix = Path(prefix_text)
        for setup_name in ("setup.bash", "local_setup.bash"):
            setup = prefix / setup_name
            if setup.exists():
                return setup, prefix

    return None, script_path.parent


def detect_ros_setup() -> Path | None:
    distro = os.environ.get("ROS_DISTRO")
    candidates: list[Path] = []
    if distro:
        candidates.append(Path("/opt/ros") / distro / "setup.bash")
    candidates.extend(Path(path) for path in sorted(glob.glob("/opt/ros/*/setup.bash")))
    for candidate in candidates:
        if candidate.exists():
            return candidate
    return None


class NavigationLauncher(tk.Tk):
    def __init__(self) -> None:
        super().__init__()
        self.title("Navigation Launcher")
        self.geometry("780x460")
        self.minsize(720, 420)

        self.process: subprocess.Popen[str] | None = None
        self.process_pgid: int | None = None
        self.reader_thread: threading.Thread | None = None
        self.self_check_failed = False
        self.close_after_stop = False

        self.source_var = tk.StringVar(value="simulation")
        self.launch_mode_var = tk.StringVar(value="navigation")
        self.node_mode_var = tk.StringVar(value="standalone")
        self.ui_size_var = tk.StringVar(value="10")
        self.config_var = tk.StringVar(value="unilidar.yaml")
        self.race_logic_var = tk.StringVar(value="mission")
        self.mission_pickup_resume_event_var = tk.StringVar(value="completed")
        self.mission_place_resume_event_var = tk.StringVar(value="completed")
        self.mission_task_radius_var = tk.StringVar(value="0.40")
        self.mission_arm_retry_period_var = tk.StringVar(value="1.0")
        self.arm_mission_service_var = tk.StringVar(value="/arm/mission_event")
        self.navigation_arm_event_service_var = tk.StringVar(value="/navigation/arm_event")

        self._build_ui()
        self.protocol("WM_DELETE_WINDOW", self._on_close)

