#!/usr/bin/env python3
"""Small desktop launcher for the navigation ROS 2 launch file."""

from __future__ import annotations

import glob
import os
import shlex
import signal
import subprocess
import threading
import tkinter as tk
from pathlib import Path
from tkinter import messagebox, ttk


UNITREE_CYCLONEDDS_SETUP = Path.home() / "unitree_ros2" / "cyclonedds_ws" / "install" / "setup.bash"

LIDAR_WS = Path.home() / "lidar" / "radar" / "unilidar" / "unitree_lidar_ros2"
LIVOX_WS = Path.home() / "lidar" / "radar" / "livox" / "livox_ws"
FAST_LIO_WS = Path.home() / "lidar" / "lio" / "fast_lio_ws"
LIDAR_INIT_DELAY = 2
FAST_LIO_INIT_DELAY = 2

FAST_LIO_CONFIG_DIR = FAST_LIO_WS / "src" / "FAST_LIO_ROS2" / "config"


def detect_workspace_setup() -> tuple[Path | None, Path]:
    script_path = Path(__file__).resolve()
    for parent in script_path.parents:
        setup_candidates = [
            parent / "install" / "setup.bash",
            parent / "install" / "local_setup.bash",
            parent / "setup.bash",
            parent / "local_setup.bash",
        ]
        for setup in setup_candidates:
            if setup.exists():
                workspace = setup.parent.parent if setup.parent.name == "install" else setup.parent
                return setup, workspace

    for prefix_text in os.environ.get("AMENT_PREFIX_PATH", "").split(os.pathsep):
        if not prefix_text:
            continue
        prefix = Path(prefix_text)
        for setup_name in ("setup.bash", "local_setup.bash"):
            setup = prefix / setup_name
            if setup.exists():
                return setup, prefix

    return None, script_path.parent


def detect_ros_setup() -> Path | None:
    distro = os.environ.get("ROS_DISTRO")
    candidates: list[Path] = []
    if distro:
        candidates.append(Path("/opt/ros") / distro / "setup.bash")
    candidates.extend(Path(path) for path in sorted(glob.glob("/opt/ros/*/setup.bash")))
    for candidate in candidates:
        if candidate.exists():
            return candidate
    return None


class NavigationLauncher(tk.Tk):
    def __init__(self) -> None:
        super().__init__()
        self.title("Navigation Launcher")
        self.geometry("780x460")
        self.minsize(720, 420)

        self.process: subprocess.Popen[str] | None = None
        self.reader_thread: threading.Thread | None = None

        self.source_var = tk.StringVar(value="simulation")
        self.launch_mode_var = tk.StringVar(value="navigation")
        self.node_mode_var = tk.StringVar(value="standalone")
        self.ui_size_var = tk.StringVar(value="10")
        self.config_var = tk.StringVar(value="unilidar.yaml")
        self.race_logic_var = tk.StringVar(value="mission")
        self.mission_resume_event_var = tk.StringVar(value="completed")
        self.mission_task_radius_var = tk.StringVar(value="0.40")
        self.mission_arm_retry_period_var = tk.StringVar(value="1.0")
        self.arm_mission_service_var = tk.StringVar(value="/arm/mission_event")
        self.navigation_arm_event_service_var = tk.StringVar(value="/navigation/arm_event")

        self._build_ui()
        self.protocol("WM_DELETE_WINDOW", self._on_close)

    def _build_ui(self) -> None:
        root = ttk.Frame(self, padding=6)
        root.grid(row=0, column=0, sticky="nsew")
        self.columnconfigure(0, weight=1)
        self.rowconfigure(0, weight=1)
        root.columnconfigure((0, 1), weight=1, uniform="launcher")
        root.rowconfigure(5, weight=1)

        source_frame = ttk.LabelFrame(root, text="信号源")
        source_frame.grid(row=0, column=0, sticky="ew", padx=(0, 3))
        source_frame.columnconfigure((0, 1), weight=1)

        ttk.Radiobutton(
            source_frame,
            text="仿真 / simulation",
            variable=self.source_var,
            value="simulation",
            command=self._sync_mode_state,
        ).grid(row=0, column=0, sticky="w", padx=6, pady=4)
        ttk.Radiobutton(
            source_frame,
            text="雷达 / radar",
            variable=self.source_var,
            value="radar",
            command=self._sync_mode_state,
        ).grid(row=0, column=1, sticky="w", padx=6, pady=4)

        mode_frame = ttk.LabelFrame(root, text="启动方式")
        mode_frame.grid(row=0, column=1, sticky="ew", padx=(3, 0))
        mode_frame.columnconfigure((0, 1), weight=1)

        ttk.Radiobutton(
            mode_frame,
            text="navigation",
            variable=self.launch_mode_var,
            value="navigation",
        ).grid(row=0, column=0, sticky="w", padx=6, pady=4)
        self.mujoco_mode = ttk.Radiobutton(
            mode_frame,
            text="MuJoCo + midware",
            variable=self.launch_mode_var,
            value="mujoco_navigation",
        )
        self.mujoco_mode.grid(row=0, column=1, sticky="w", padx=6, pady=4)

        # ---- 雷达设置 ----
        self.radar_frame = ttk.LabelFrame(root, text="雷达设置")
        self.radar_frame.grid(row=1, column=0, sticky="ew", padx=(0, 3), pady=(4, 0))
        self.radar_frame.columnconfigure(1, weight=1)

        ttk.Label(self.radar_frame, text="config_file:").grid(
            row=0, column=0, sticky="w", padx=6, pady=4
        )
        self.config_combo = ttk.Combobox(
            self.radar_frame,
            textvariable=self.config_var,
            values=self._detect_config_files(),
            state="readonly",
            width=20,
        )
        self.config_combo.grid(row=0, column=1, sticky="ew", padx=(4, 6), pady=4)

        # workspace status indicators
        lidar_ok = (LIDAR_WS / "install" / "setup.bash").exists()
        livox_ok = (LIVOX_WS / "install" / "setup.bash").exists()
        lio_ok = (FAST_LIO_WS / "install" / "setup.bash").exists()
        lidar_mark = "✓" if lidar_ok else "✗"
        livox_mark = "✓" if livox_ok else "✗"
        lio_mark = "✓" if lio_ok else "✗"

        self.radar_status_label = ttk.Label(
            self.radar_frame,
            text=f"  unitree {lidar_mark}    livox {livox_mark}    fast_lio {lio_mark}",
        )
        self.radar_status_label.grid(row=1, column=0, columnspan=2, sticky="w", padx=6, pady=(0, 4))

        node_frame = ttk.LabelFrame(root, text="节点角色")
        node_frame.grid(row=1, column=1, sticky="ew", padx=(3, 0), pady=(4, 0))
        node_frame.columnconfigure((0, 1, 2), weight=1)

        ttk.Radiobutton(
            node_frame,
            text="standalone",
            variable=self.node_mode_var,
            value="standalone",
            command=self._sync_mode_state,
        ).grid(row=0, column=0, sticky="w", padx=6, pady=4)
        ttk.Radiobutton(
            node_frame,
            text="core",
            variable=self.node_mode_var,
            value="core",
            command=self._sync_mode_state,
        ).grid(row=0, column=1, sticky="w", padx=6, pady=4)
        ttk.Radiobutton(
            node_frame,
            text="remote UI",
            variable=self.node_mode_var,
            value="remote_ui",
            command=self._sync_mode_state,
        ).grid(row=0, column=2, sticky="w", padx=6, pady=4)

        size_frame = ttk.LabelFrame(root, text="UI 大小")
        size_frame.grid(row=2, column=0, sticky="ew", columnspan=2, pady=(4, 0))
        size_frame.columnconfigure(1, weight=1)

        ttk.Label(size_frame, text="导航界面大小 5-15").grid(
            row=0,
            column=0,
            sticky="w",
            padx=6,
            pady=4,
        )
        ttk.Spinbox(
            size_frame,
            from_=5,
            to=15,
            textvariable=self.ui_size_var,
            width=6,
        ).grid(row=0, column=1, sticky="w", padx=6, pady=4)

        race_frame = ttk.LabelFrame(root, text="赛事逻辑")
        race_frame.grid(row=3, column=0, columnspan=2, sticky="ew", pady=(4, 0))
        race_frame.columnconfigure((1, 7), weight=1)

        ttk.Radiobutton(
            race_frame,
            text="obstacle",
            variable=self.race_logic_var,
            value="obstacle",
        ).grid(row=0, column=0, sticky="w", padx=6, pady=4)
        ttk.Radiobutton(
            race_frame,
            text="mission",
            variable=self.race_logic_var,
            value="mission",
        ).grid(row=0, column=1, sticky="w", padx=6, pady=4)
        ttk.Label(race_frame, text="恢复:").grid(row=0, column=2, sticky="e", padx=(6, 2), pady=4)
        ttk.Combobox(
            race_frame,
            textvariable=self.mission_resume_event_var,
            values=("ack", "grabbed", "completed"),
            state="readonly",
            width=10,
        ).grid(row=0, column=3, sticky="w", padx=(2, 6), pady=4)
        ttk.Label(race_frame, text="半径:").grid(row=0, column=4, sticky="e", padx=(6, 2), pady=4)
        ttk.Entry(race_frame, textvariable=self.mission_task_radius_var, width=8).grid(
            row=0,
            column=5,
            sticky="w",
            padx=(2, 6),
            pady=4,
        )
        ttk.Label(race_frame, text="重试:").grid(row=0, column=6, sticky="e", padx=(6, 2), pady=4)
        ttk.Entry(race_frame, textvariable=self.mission_arm_retry_period_var, width=8).grid(
            row=0,
            column=7,
            sticky="w",
            padx=(2, 6),
            pady=4,
        )
        ttk.Label(race_frame, text="arm srv:").grid(row=1, column=0, sticky="e", padx=(6, 2), pady=(0, 4))
        ttk.Entry(race_frame, textvariable=self.arm_mission_service_var, width=22).grid(
            row=1,
            column=1,
            columnspan=3,
            sticky="ew",
            padx=(2, 6),
            pady=(0, 4),
        )
        ttk.Label(race_frame, text="nav srv:").grid(row=1, column=4, sticky="e", padx=(6, 2), pady=(0, 4))
        ttk.Entry(race_frame, textvariable=self.navigation_arm_event_service_var, width=22).grid(
            row=1,
            column=5,
            columnspan=3,
            sticky="ew",
            padx=(2, 6),
            pady=(0, 4),
        )

        action_frame = ttk.Frame(root)
        action_frame.grid(row=4, column=0, columnspan=2, sticky="ew", pady=(6, 4))
        action_frame.columnconfigure(2, weight=1)

        self.start_button = ttk.Button(action_frame, text="启动", command=self.start_launch)
        self.start_button.grid(row=0, column=0, padx=(0, 8))
        self.stop_button = ttk.Button(action_frame, text="停止", command=self.stop_launch, state=tk.DISABLED)
        self.stop_button.grid(row=0, column=1, padx=(0, 8))
        self.status_label = ttk.Label(action_frame, text="未启动")
        self.status_label.grid(row=0, column=2, sticky="e")

        log_frame = ttk.LabelFrame(root, text="日志")
        log_frame.grid(row=5, column=0, columnspan=2, sticky="nsew")
        log_frame.columnconfigure(0, weight=1)
        log_frame.rowconfigure(0, weight=1)

        self.log_text = tk.Text(log_frame, height=3, wrap="word", state=tk.DISABLED)
        self.log_text.grid(row=0, column=0, sticky="nsew")
        scrollbar = ttk.Scrollbar(log_frame, orient="vertical", command=self.log_text.yview)
        scrollbar.grid(row=0, column=1, sticky="ns")
        self.log_text.configure(yscrollcommand=scrollbar.set)

        self._sync_mode_state()

    def _sync_mode_state(self) -> None:
        if self.source_var.get() == "radar" or self.node_mode_var.get() != "standalone":
            self.launch_mode_var.set("navigation")
            self.mujoco_mode.configure(state=tk.DISABLED)
        else:
            self.mujoco_mode.configure(state=tk.NORMAL)

        if self.source_var.get() == "radar":
            self._set_frame_state(self.radar_frame, tk.NORMAL)
        else:
            self._set_frame_state(self.radar_frame, tk.DISABLED)

    @staticmethod
    def _set_frame_state(frame: ttk.Frame, state: str) -> None:
        for child in frame.winfo_children():
            try:
                child.configure(state=state)
            except tk.TclError:
                pass

    @staticmethod
    def _detect_config_files() -> list[str]:
        if not FAST_LIO_CONFIG_DIR.exists():
            return ["unilidar.yaml"]
        configs = sorted(
            p.name for p in FAST_LIO_CONFIG_DIR.glob("*.yaml")
        )
        return configs if configs else ["unilidar.yaml"]

    def append_log(self, line: str) -> None:
        self.log_text.configure(state=tk.NORMAL)
        self.log_text.insert(tk.END, line)
        self.log_text.see(tk.END)
        self.log_text.configure(state=tk.DISABLED)

    def start_launch(self) -> None:
        if self.process is not None:
            messagebox.showinfo("Navigation Launcher", "当前已经有启动进程。", parent=self)
            return

        local_setup, workspace = detect_workspace_setup()
        if local_setup is None:
            messagebox.showerror(
                "Navigation Launcher",
                "找不到 workspace setup 文件。请先在包含 navigation 的 workspace 里执行 colcon build。",
                parent=self,
            )
            return

        try:
            if self.source_var.get() == "radar":
                config_file = self.config_var.get()
                lidar_ws, _ = self._resolve_lidar_driver(config_file)

                missing = []
                if not (Path(lidar_ws) / "install" / "setup.bash").exists():
                    missing.append(str(lidar_ws))
                if not (FAST_LIO_WS / "install" / "setup.bash").exists():
                    missing.append(str(FAST_LIO_WS))
                if missing:
                    messagebox.showerror(
                        "Navigation Launcher",
                        f"雷达工作空间缺少 install/setup.bash:\n" + "\n".join(f"  • {p}" for p in missing),
                        parent=self,
                    )
                    return

            command = self._build_launch_command(local_setup)
        except ValueError as exc:
            messagebox.showerror("Navigation Launcher", str(exc), parent=self)
            return

        self.append_log(f"$ {command}\n")

        try:
            self.process = subprocess.Popen(
                ["bash", "-lc", command],
                cwd=str(workspace),
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                bufsize=1,
                preexec_fn=os.setsid,
            )
        except OSError as exc:
            self.process = None
            messagebox.showerror("Navigation Launcher", f"启动失败:\n{exc}", parent=self)
            return

        self.start_button.configure(state=tk.DISABLED)
        self.stop_button.configure(state=tk.NORMAL)
        self.status_label.configure(text="运行中")
        self.reader_thread = threading.Thread(target=self._read_process_output, daemon=True)
        self.reader_thread.start()

    def _build_launch_command(self, local_setup: Path) -> str:
        parts: list[str] = ["set -e"]
        ros_setup = detect_ros_setup()
        if ros_setup is not None:
            parts.append(f"source {shlex.quote(str(ros_setup))}")
        if UNITREE_CYCLONEDDS_SETUP.exists():
            parts.append(f"source {shlex.quote(str(UNITREE_CYCLONEDDS_SETUP))}")

        source = self.source_var.get()
        mode = self.launch_mode_var.get()
        node_mode = self.node_mode_var.get()

        # radar pipeline: lidar → fast_lio before navigation
        if source == "radar":
            parts.extend(self._build_radar_pipeline_commands())

        parts.append(f"source {shlex.quote(str(local_setup))}")

        executable, node_role, show_window = self._selected_navigation_node()
        ui_size = self._selected_ui_size()
        mission_task_radius = self._selected_positive_float(self.mission_task_radius_var, "0.40")
        mission_arm_retry_period = self._selected_positive_float(self.mission_arm_retry_period_var, "1.0")
        size_args = [
            f"ui_size:={ui_size}",
            "map_padding_px:=20.0",
            "panel_collapsed:=false",
        ]
        race_args = [
            f"race_logic:={self.race_logic_var.get()}",
            f"mission_resume_event:={self.mission_resume_event_var.get()}",
            f"mission_task_radius:={mission_task_radius}",
            f"mission_arm_retry_period:={mission_arm_retry_period}",
            f"arm_mission_service:={self.arm_mission_service_var.get()}",
            f"navigation_arm_event_service:={self.navigation_arm_event_service_var.get()}",
        ]
        if mode == "mujoco_navigation" and source == "simulation" and node_mode == "standalone":
            launch_args = [
                "ros2",
                "launch",
                "navigation",
                "mujoco_navigation.launch.py",
                f"cmd_vel_topic:=/cmd_vel",
                *size_args,
                *race_args,
            ]
        else:
            launch_args = [
                "ros2",
                "launch",
                "navigation",
                "navigation.launch.py",
                f"navigation_executable:={executable}",
                f"node_role:={node_role}",
                f"source:={source}",
                f"show_window:={'true' if show_window else 'false'}",
                "sim_odom_topic:=/odom",
                "radar_odom_topic:=/Odometry",
                "radar_calibration_topic:=/Odometry",
                *size_args,
                *race_args,
            ]
        parts.append("exec " + " ".join(shlex.quote(arg) for arg in launch_args))
        return " && ".join(parts)

    @staticmethod
    def _tilde(path: Path) -> str:
        """将 home 下的绝对路径转成 ~/... 形式，方便 bash 命令跨用户移植。"""
        home = Path.home()
        try:
            return "~/" + str(path.relative_to(home))
        except ValueError:
            return str(path)

    def _build_radar_pipeline_commands(self) -> list[str]:
        config_file = self.config_var.get()
        lidar_ws, launch_args = self._resolve_lidar_driver(config_file)
        lidar_setup = Path(lidar_ws) / "install" / "setup.bash"
        lio_setup = FAST_LIO_WS / "install" / "setup.bash"

        # 注意：source 路径不能用 shlex.quote() 包起来 — 单引号会阻止 ~ 展开
        # 路径来自 Path.home() 的子目录，不含空格或特殊字符，直接拼接是安全的
        lidar_source_path = self._tilde(lidar_setup)
        lio_source_path = self._tilde(lio_setup)

        return [
            # Step 1: lidar driver (subshell for clean environment)
            # 不能用 "& &&" — bash 里 & 是命令终止符，后面跟 && 会语法错误
            # 所以把 & 和 sleep 写进同一个 part，避免 join(" && ") 插入 &&
            f"(source {lidar_source_path} && "
            f"{' '.join(shlex.quote(arg) for arg in launch_args)}) & "
            f"sleep {LIDAR_INIT_DELAY}",
            # Step 2: fast_lio (subshell for clean environment)
            f"(source {lio_source_path} && "
            f"ros2 launch fast_lio mapping.launch.py config_file:={shlex.quote(config_file)}) & "
            f"sleep {FAST_LIO_INIT_DELAY}",
        ]

    @staticmethod
    def _resolve_lidar_driver(config_file: str) -> tuple[str, list[str]]:
        """根据 config 文件名前缀决定使用哪个雷达驱动。

        Returns:
            (workspace_path, launch_args) — e.g. (str(LIVOX_WS), ["ros2", "launch", "livox_ros_driver2", "msg_MID360_launch.py"])
        Raises:
            ValueError: 不支持的 config 文件前缀。
        """
        if config_file.startswith("mid360"):
            return (
                str(LIVOX_WS),
                ["ros2", "launch", "livox_ros_driver2", "msg_MID360_launch.py"],
            )
        if config_file.startswith("unilidar"):
            return (
                str(LIDAR_WS),
                ["ros2", "launch", "unitree_lidar_ros2", "launch.py"],
            )
        raise ValueError(
            f"不支持该 config_file 对应的雷达驱动: {config_file}\n"
            "config_file 必须以 mid360 或 unilidar 开头。"
        )

    def _selected_navigation_node(self) -> tuple[str, str, bool]:
        node_mode = self.node_mode_var.get()
        if node_mode == "core":
            return "navigation_core", "core", False
        if node_mode == "remote_ui":
            return "navigation_remote_ui", "remote_ui", True
        return "navigation_map", "standalone", True

    def _selected_ui_size(self) -> int:
        try:
            return min(15, max(5, int(self.ui_size_var.get())))
        except ValueError:
            self.ui_size_var.set("10")
            return 10

    @staticmethod
    def _selected_positive_float(value_var: tk.StringVar, fallback: str) -> str:
        try:
            value = float(value_var.get())
            if value <= 0.0:
                raise ValueError
        except ValueError:
            value_var.set(fallback)
            return fallback
        return f"{value:.3f}"

    def _read_process_output(self) -> None:
        assert self.process is not None
        assert self.process.stdout is not None
        for line in self.process.stdout:
            self.after(0, self.append_log, line)
        return_code = self.process.wait()
        self.after(0, self._process_finished, return_code)

    def _process_finished(self, return_code: int) -> None:
        self.append_log(f"\n[process exited with code {return_code}]\n")
        self.process = None
        self.start_button.configure(state=tk.NORMAL)
        self.stop_button.configure(state=tk.DISABLED)
        self.status_label.configure(text="已退出")

    def stop_launch(self) -> None:
        if self.process is None:
            return
        self.append_log("\n[stopping launch process]\n")
        try:
            os.killpg(os.getpgid(self.process.pid), signal.SIGINT)
        except ProcessLookupError:
            return
        self.after(4000, self._terminate_if_needed)

    def _terminate_if_needed(self) -> None:
        if self.process is None or self.process.poll() is not None:
            return
        try:
            os.killpg(os.getpgid(self.process.pid), signal.SIGTERM)
        except ProcessLookupError:
            pass

    def _on_close(self) -> None:
        if self.process is not None:
            if not messagebox.askyesno(
                "Navigation Launcher",
                "启动进程还在运行，是否停止并退出？",
                parent=self,
            ):
                return
            self.stop_launch()
        self.destroy()


if __name__ == "__main__":
    app = NavigationLauncher()
    app.mainloop()
