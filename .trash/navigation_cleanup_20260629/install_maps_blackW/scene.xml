      <geom name="bridge_support_5" type="box" size="0.20 2.00 0.1486482" pos="5.9196155 0 0.1486482" rgba="0.45 0.45 0.6 1" friction="1 0.005 0.0001"/>
      <geom name="bridge_5" type="box" size="0.20 2.00 0.025" pos="5.9196155 0 0.3222964" rgba="0.55 0.55 0.7 1" friction="1 0.005 0.0001"/>
